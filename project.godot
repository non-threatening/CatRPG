; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Secret of CAT"
run/main_scene="uid://f6hapagaurf5"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/image="uid://c257bwkqgjp38"
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://bop826olg37j2"

[autoload]

ControllerIcons="*uid://dor6pohdms78l"
TimeSystem="*res://00_Globals/global_time_system.gd"
AudioManager="*res://00_Globals/global_audio_manager.gd"
LevelManager="*res://00_Globals/global_level_manager.gd"
PlayerHud="*res://GUI/player_hud/player_hud.tscn"
PlayerManager="*res://00_Globals/global_player_manager.gd"
SceneTransition="*res://GUI/scene_transition/scene_transition.tscn"
PauseMenu="*res://GUI/pause_menu/PauseMenu.tscn"
EffectManager="*res://00_Globals/global_effect_manager.gd"
ShopMenu="*res://GUI/shop_menu/shop_menu.tscn"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
Shortcuts="*res://Quests/scripts/quest_system_shortcuts.gd"
QuestVars="*res://00_Globals/global_quest_vars.gd"
NpcManager="*res://00_Globals/global_npc_manager.gd"
SteamController="*res://00_Globals/Steam/steam_controller.gd"
StatsManager="*res://00_Globals/global_stats_manager.gd"
SignalBus="*res://00_Globals/global_signal_bus.gd"
SaveManager="*res://00_Globals/global_save_manager.gd"
QuestSystem="*uid://b77kvbliweux5"

[debug]

file_logging/enable_file_logging=true
gdscript/warnings/unused_parameter=0
gdscript/warnings/standalone_expression=0

[dialogue_manager]

runtime/balloon_path="res://Dialogue/SpeechBubbles/speech_bubble/speech_bubble.tscn"
editor/wrap_long_lines=true
runtime/state_autoload_shortcuts=["Shortcuts"]

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1280
window/size/window_height_override=800
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/Todo_Manager/plugin.cfg", "res://addons/controller_icons/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg", "res://addons/quest_system/plugin.cfg")

[file_customization]

folder_colors={
"res://Dialogue/": "pink",
"res://GUI/": "orange",
"res://Maps/": "teal",
"res://Player/": "green",
"res://Quests/": "pink",
"res://npc/": "purple"
}

[global_group]

tilemaps="tilemaps with footstep sounds and stuff"

[gui]

theme/default_font_hinting=0
theme/default_font_multichannel_signed_distance_field=true
theme/default_font_generate_mipmaps=true
theme/custom_font="uid://c63g2n0bmlx53"

